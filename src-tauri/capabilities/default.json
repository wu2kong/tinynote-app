{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "local": true,
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.tinynotes" },
        { "path": "$HOME/.tinynotes/**" },
        { "path": "$HOME/**/.tinynotes" },
        { "path": "$HOME/**/.tinynotes/**" },
        { "path": "$HOME/**/.tinynotes/*" },
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "**/.tinynotes" },
        { "path": "**/.tinynotes/**" },
        { "path": "**/.tinynotes/*" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.tinynotes" },
        { "path": "$HOME/.tinynotes/**" },
        { "path": "$HOME/**/.tinynotes" },
        { "path": "$HOME/**/.tinynotes/**" },
        { "path": "$HOME/**/.tinynotes/*" },
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "**/.tinynotes" },
        { "path": "**/.tinynotes/**" },
        { "path": "**/.tinynotes/*" },
        { "path": "**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "shell:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME" },
        { "path": "**" }
      ]
    },
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-url",
    "opener:allow-default-urls",
    "allow-get-app-dir",
    "allow-backup",
    "allow-sync",
    "allow-updater",
    "allow-llm",
    "core:menu:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create"
  ]
}
